rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. RBAC Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function hasRole(role) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    function isAdmin() {
      return hasRole('ADMIN') || hasRole('OWNER');
    }
    function isStaff() {
      return hasRole('STAFF') || hasRole('MARKETING');
    }
    function isMarketing() {
      return hasRole('MARKETING');
    }
    function isAccountant() {
      return hasRole('ACCOUNTANT');
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isSelfByEmail(email) {
      return isSignedIn()
        && email is string
        && request.auth.token.email is string
        && request.auth.token.email == email;
    }
    function canReadBookingById(bookingId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/bookings/$(bookingId))
        && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid
          || isSelfByEmail(get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientEmail)
        );
    }
    function canReadInvoiceById(invoiceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/invoices/$(invoiceId))
        && canReadBookingById(get(/databases/$(database)/documents/invoices/$(invoiceId)).data.eventId);
    }

    // --- 2. Schema Validation Helpers ---
    
    function isValidBooking() {
      let data = request.resource.data;
      return data.keys().hasAll(['clientId', 'status', 'eventDate'])
        && data.status in ['inquiry', 'quoted', 'confirmed', 'completed', 'cancelled']
        && (!data.keys().hasAny(['startTime']) || data.startTime is string)
        && (!data.keys().hasAny(['endTime']) || data.endTime is string)
        && (!data.keys().hasAny(['venueAddress']) || data.venueAddress is string)
        && (!data.keys().hasAny(['eventType']) || data.eventType in ['rental', 'catering', 'both'])
        && (!data.keys().hasAny(['deliveryStatus']) || data.deliveryStatus in ['scheduled', 'out_for_delivery', 'delivered', 'pickup', 'returned'])
        && (!data.keys().hasAny(['assignedStaffIds']) || data.assignedStaffIds is list)
        && (!data.keys().hasAny(['internalNotes']) || data.internalNotes is string)
        && (!data.keys().hasAny(['clientName']) || data.clientName is string)
        && (!data.keys().hasAny(['clientEmail']) || data.clientEmail is string)
        && (!data.keys().hasAny(['sourceQuoteId']) || data.sourceQuoteId is string);
    }
    function clientCanAcceptQuote() {
      return isSelfByEmail(resource.data.customerEmail)
        && request.resource.data.customerEmail == resource.data.customerEmail
        && request.resource.data.status == 'accepted'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status']);
    }

    // --- 3. Collection Rules ---

    // USERS: Admin controls all; Users read self
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'CLIENT') || isAdmin();
      // Users can update their own data but NOT their role
      allow update: if isAdmin() || (isSelf(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // CUSTOMERS: Staff/Admin manage; Customers read/update self
    match /customers/{customerId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || isSelf(customerId) || (resource.data.id == request.auth.uid) || isSelfByEmail(resource.data.email);
      allow create: if isStaff() || isAdmin() || isAccountant() || (isSignedIn() && ((request.resource.data.id == request.auth.uid) || isSelfByEmail(request.resource.data.email)));
      allow update: if isStaff() || isAdmin() || isAccountant() || (
        isSignedIn()
        && ((resource.data.id == request.auth.uid) || isSelf(customerId) || isSelfByEmail(resource.data.email))
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
      );
      allow delete: if isAdmin();
    }

    // CATALOG: Public Read, Admin Write
    match /catalog_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin() || isMarketing();
    }

    // EMPLOYEES: Admin/Accountant/Staff access
    match /employees/{employeeId} {
      allow read: if isAdmin() || isAccountant() || isStaff() || isSelf(employeeId);
      allow create, update: if isAdmin() || isAccountant();
      allow delete: if isAdmin();
    }

    // BOOKINGS: The Core Logic
    match /bookings/{bookingId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || isSelf(resource.data.clientId) || isSelfByEmail(resource.data.clientEmail);
      allow create: if (isStaff() || isAdmin() || isAccountant()) && isValidBooking();
      allow update: if (isStaff() || isAdmin() || isAccountant()) && isValidBooking();
    }

    // BOOKING REQUESTS: Public Write
    match /booking_requests/{requestId} {
      allow create: if true;
      allow read: if isStaff() || isAdmin() || isAccountant() || isSelf(resource.data.clientId) || isSelfByEmail(resource.data.customerEmail);
      allow update: if isStaff() || isAdmin() || isAccountant() || clientCanAcceptQuote();
    }

    // INVOICES: Admin/Staff Manage, Client Read Only
    match /invoices/{invoiceId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || canReadBookingById(resource.data.eventId);
      allow write: if isAdmin() || isAccountant();
    }

    // PAYMENTS: Webhooks create, Admin manage
    match /payments/{paymentId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || canReadInvoiceById(resource.data.invoiceId);
      allow create: if true; // Webhooks or Client Portal
      allow update, delete: if isAdmin() || isAccountant();
    }

    // AUDIT LOGS: Append Only / Immutable
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      // Allow creation if the actor matches the logged-in user
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }

    // STAFF LOGS: Time Tracking
    match /worklogs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.employeeId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // PAY STUBS: Admin/Accountant Generate, Staff Read Own
    match /payStubs/{slipId} {
      allow read: if isAdmin() || (isStaff() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || isAccountant();
    }

    // PAY PERIODS: Admin/Accountant manage
    match /payPeriods/{periodId} {
      allow read: if isAdmin() || isAccountant();
      allow write: if isAdmin() || isAccountant();
    }

    // SITE CONTENT: Read all, Admin/Marketing Write
    match /site_content/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isMarketing();
    }

    // SETTINGS: Admin Manage Only
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
