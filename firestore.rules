rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. RBAC Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function hasRole(role) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    function isAdmin() {
      return hasRole('ADMIN') || hasRole('OWNER');
    }
    function isStaff() {
      return hasRole('STAFF') || hasRole('MARKETING');
    }
    function isMarketing() {
      return hasRole('MARKETING');
    }
    function isAccountant() {
      return hasRole('ACCOUNTANT');
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Schema Validation Helpers ---
    
    // Validate Booking Structure to ensure Data Integrity
    function isValidBooking() {
      let data = request.resource.data;
      return data.keys().hasAll(['clientId', 'status', 'eventDate', 'items', 'total'])
        && data.status in ['inquiry', 'quoted', 'confirmed', 'completed', 'cancelled']
        && data.total is number
        && data.items is list;
    }

    // --- 3. Collection Rules ---

    // USERS: Admin controls all; Users read self
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'CLIENT') || isAdmin();
      // Users can update their own data but NOT their role
      allow update: if isAdmin() || (isSelf(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // CUSTOMERS: Staff/Admin manage; Customers read/update self
    match /customers/{customerId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || (isSignedIn() && resource.data.id == request.auth.uid);
      allow create: if isStaff() || isAdmin() || (isSignedIn() && request.resource.data.id == request.auth.uid);
      allow update: if isStaff() || isAdmin() || (isSignedIn() && resource.data.id == request.auth.uid && request.resource.data.id == resource.data.id);
      allow delete: if isAdmin();
    }

    // CATALOG: Public Read, Admin Write
    match /catalog_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin() || isMarketing();
    }

    // EMPLOYEES: Admin/Accountant/Staff access
    match /employees/{employeeId} {
      allow read: if isAdmin() || isAccountant() || isStaff() || isSelf(employeeId);
      allow create, update: if isAdmin() || isAccountant();
      allow delete: if isAdmin();
    }

    // BOOKINGS: The Core Logic
    match /bookings/{bookingId} {
      // READ: Owner or Staff/Admin/Accountant
      allow read: if isStaff() || isAdmin() || isAccountant() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      
      // CREATE: Staff/Admin (Public uses booking_requests)
      allow create: if (isStaff() || isAdmin()) && isValidBooking();

      // UPDATE:
      // 1. Admin can do anything (including overrides).
      // 2. Staff can update if they are NOT enabling an override.
      // 3. Client can only update specific fields if Status is DRAFT (optional, handled by booking_requests usually)
      allow update: if isAdmin() || (
        isStaff() 
        && isValidBooking()
        // Prevent Staff from toggling the adminOverride active flag
        && (
           !request.resource.data.adminOverride.isActive 
           || request.resource.data.adminOverride.isActive == resource.data.adminOverride.isActive
        )
      );
    }

    // BOOKING REQUESTS: Public Write
    match /booking_requests/{requestId} {
      allow create: if true;
      allow read, update: if isStaff() || isAdmin() || isAccountant();
    }

    // INVOICES: Admin/Staff Manage, Client Read Only
    match /invoices/{invoiceId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || (isSignedIn() && get(/databases/$(database)/documents/bookings/$(resource.data.eventId)).data.clientId == request.auth.uid);
      allow write: if isAdmin() || isAccountant();
    }

    // PAYMENTS: Webhooks create, Admin manage
    match /payments/{paymentId} {
      allow read: if isStaff() || isAdmin() || isAccountant() || (isSignedIn() && get(/databases/$(database)/documents/bookings/$(get(/databases/$(database)/documents/invoices/$(resource.data.invoiceId)).data.eventId)).data.clientId == request.auth.uid);
      allow create: if true; // Webhooks or Client Portal
      allow update, delete: if isAdmin() || isAccountant();
    }

    // AUDIT LOGS: Append Only / Immutable
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      // Allow creation if the actor matches the logged-in user
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }

    // STAFF LOGS: Time Tracking
    match /worklogs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.employeeId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // PAY STUBS: Admin/Accountant Generate, Staff Read Own
    match /payStubs/{slipId} {
      allow read: if isAdmin() || (isStaff() && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || isAccountant();
    }

    // PAY PERIODS: Admin/Accountant manage
    match /payPeriods/{periodId} {
      allow read: if isAdmin() || isAccountant();
      allow write: if isAdmin() || isAccountant();
    }

    // SITE CONTENT: Read all, Admin/Marketing Write
    match /site_content/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isMarketing();
    }

    // SETTINGS: Admin Manage Only
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
